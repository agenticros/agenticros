{
  "name": "@agenticros-skills/{{slug}}",
  "version": "0.1.0",
  "type": "module",
  "description": "{{description}}",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "npx agenticros skills dev"
  },
  "agenticros": {
    "id": "{{slug}}",
    "displayName": "{{displayName}}",
    "description": "{{description}}",
    "tutorial": false,
    "categories": [
      "human-interaction",
      "navigation"
    ],
    "screenshots": [
      "docs/icon.png"
    ],
    "capabilities": [
      {
        "id": "{{toolName}}",
        "verb": "wave",
        "description": "{{description}}",
        "interruptible": true,
        "blocks_base": true
      }
    ]
  },
  "dependencies": {
    "@agenticros/core": "^0.8.0",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "agenticros",
    "robot",
    "cmd_vel"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
